{
  "name": "@coin-district/coindistrict-core",
  "version": "1.0.1",
  "private": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "description": "Foundry-based ERC-3643 smart contracts for Coin District",
  "license": "GPL-3.0",
  "scripts": {
    "build": "bash scripts/generate-abis.sh && bash scripts/export-contracts-source.sh",
    "build:abis": "bash scripts/generate-abis.sh",
    "export:contracts": "bash scripts/export-contracts-source.sh",
    "prepublishOnly": "pnpm build",
    "test": "forge test",
    "format": "forge fmt && prettier --write \"**/*.{json,md,yaml,yml}\"",
    "lint": "forge lint",
    "prepare": "husky"
  },
  "files": [
    "contracts",
    "abis",
    "export",
    "foundry.toml",
    "remappings.txt",
    "foundry.lock",
    "config",
    "out"
  ],
  "devDependencies": {
    "husky": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
